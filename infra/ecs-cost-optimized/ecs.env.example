# Copy to infra/ecs-cost-optimized/ecs.env and fill values

# Required AWS context
AWS_REGION=eu-west-1
PROJECT_NAME=elimuai
STACK_NAME=elimuai-ecs

# Required app secrets
DATABASE_URL=postgresql://user:password@your-db-endpoint:5432/elimuai_db
REDIS_URL=redis://your-redis-endpoint:6379
JWT_SECRET=replace-with-64-char-random-secret
ANTHROPIC_API_KEY=replace-with-real-anthropic-key

# Frontend URL for backend CORS. On first deploy use placeholder and update later.
FRONTEND_URL=http://localhost

# Cost settings
DESIRED_COUNT=1
TASK_CPU=512
TASK_MEMORY=1024
SPOT_WEIGHT=4
ON_DEMAND_WEIGHT=1
