# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://elimuai_user:your_password@localhost:5432/elimuai_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=elimuai_db
DB_USER=elimuai_user
DB_PASSWORD=your_secure_password_here

# ─── REDIS (Caching & Sessions) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT AUTH ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── ANTHROPIC AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── M-PESA (Safaricom Daraja API) ───────────────────────────────────────────
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
# sandbox: https://sandbox.safaricom.co.ke | production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=https://api.elimuai.africa/api/payments/mpesa/callback

# ─── AIRTEL MONEY ────────────────────────────────────────────────────────────
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_CALLBACK_URL=https://api.elimuai.africa/api/payments/airtel/callback

# ─── SMS (Africa's Talking) ───────────────────────────────────────────────────
AFRICASTALKING_API_KEY=your_at_api_key
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=ElimuAI

# ─── EMAIL (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_FROM=noreply@elimuai.africa
EMAIL_FROM_NAME=ElimuAI

# ─── FILE STORAGE (Cloudinary) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=30
