# ─── Images ───────────────────────────────────────────────────────────────────
BACKEND_IMAGE=ghcr.io/dfrey3820/elimuai-backend:v1.1.0
FRONTEND_IMAGE=ghcr.io/dfrey3820/elimuai-frontend:v1.1.0
MPESA_IMAGE=ghcr.io/dfrey3820/elimuai-mpesa:v1.1.0

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://elimuai.africa
JWT_SECRET=change_me_min_64_chars

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=elimuai_db
POSTGRES_USER=elimuai_user
POSTGRES_PASSWORD=change_me
DATABASE_SSL=false

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Queue (shared secret between backend & mpesa-service) ───────────────────
QUEUE_HMAC_SECRET=change_me_min_64_chars_random

# ─── M-Pesa Service ──────────────────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_BASE_URL=https://pay.elimuai.africa
MPESA_ADMIN_API_KEY=change_me_strong_random_key

# ─── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=change_me
EMAIL_FROM=noreply@elimuai.africa
EMAIL_FROM_NAME=ElimuAI

# ─── SMS ──────────────────────────────────────────────────────────────────────
AFRICASTALKING_API_KEY=change_me
AFRICASTALKING_USERNAME=change_me
AFRICASTALKING_SENDER_ID=ElimuAI

# ─── Storage ──────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=change_me
CLOUDINARY_API_KEY=change_me
CLOUDINARY_API_SECRET=change_me
