# Container images from GHCR
BACKEND_IMAGE=ghcr.io/dfrey3820/elimuai-backend:latest
FRONTEND_IMAGE=ghcr.io/dfrey3820/elimuai-frontend:latest

# Public URL used for CORS
FRONTEND_URL=http://your-ec2-public-ip

# Local Postgres for lowest cost
POSTGRES_DB=elimuai_db
POSTGRES_USER=elimuai_user
POSTGRES_PASSWORD=change_this_db_password

# App secrets
JWT_SECRET=replace_with_64_plus_char_secret
ANTHROPIC_API_KEY=replace_with_real_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional hardening for production-like behavior
NODE_ENV=production

# Optional integrations (leave blank if unused)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=ElimuAI
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=ElimuAI
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
